{
  "name": "xuan-agent",
  "version": "0.1.0",
  "private": true,
  "description": "以紫微斗数为起点的 Agentic RAG 工作台。",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc -p tsconfig.workspace.json --noEmit",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "demo:ziwei": "pnpm build && pnpm --filter @xuan/cli demo:ziwei",
    "rag:index-private": "pnpm --filter @xuan/ingest build && node tools/ingest/dist/index.js index-private"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
